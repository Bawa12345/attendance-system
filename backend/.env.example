# ====================================================
# Backend Environment Variables
# Copy this to .env and fill in the values.
# NEVER commit .env to source control.
# ====================================================

# JWT secret — use a long random string in production
JWT_SECRET=replace_with_a_long_random_secret_here

# Google Cloud project details (set automatically by Cloud Run, but define locally)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# Firebase Admin SDK — path to your service account key (local dev only)
# On Cloud Run, use GOOGLE_APPLICATION_CREDENTIALS or Workload Identity instead.
GOOGLE_APPLICATION_CREDENTIALS=./serviceAccountKey.json

# Port (Cloud Run sets this automatically; keep as 8080)
PORT=8080
